# 基础站点配置
NUXT_SITE_URL=http://127.0.0.1
NUXT_SITE_NAME=My Awesome Website
NUXT_SITE_DESCRIPTION=My Awesome Website description

# API 相关
API_SECRET=api_secret_token

NUXT_PUBLIC_API_BASE=/dev-api
NUXT_PUBLIC_API_OTHER_BASE=/dev-api-other

NUXT_PUBLIC_API_URL=http://127.0.0.1:5000
NUXT_PUBLIC_API_OTHER_URL=http://127.0.0.1:6000

# Redis 生产配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=''
REDIS_DB=0
REDIS_TLS=false

# 其他必要变量
NODE_ENV=development